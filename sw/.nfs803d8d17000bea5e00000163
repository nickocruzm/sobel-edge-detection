import sys
import numpy as np
from PIL import Image
from scipy.signal import convolve2d

# Convolution kernel
Gx = np.array([[1,2,1],
               [0,0,0],
               [1,2,1]])

# Load grayscale image and resize to 32x32
img_path = sys.argv[1]
img = Image.open(img_path).convert("L").resize((5,5))
img = np.array(img, dtype=np.int32)

out = convolve2d(img, Gx, mode='valid')

# Save the output
np.savetxt("sw_output.txt", out, fmt="%d")